		"LS_ADLS_GEN2_SourceFolder_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_GEN2_SourceFolder'"
		},
		"LS_ADLS_GEN_Validation_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_GEN_Validation'"
		},
		"LS_ADLS_Gen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_Gen2'"
		},
		"LS_DELETE_OLD_FILES_accountKey": {
			"type": "secureString",
