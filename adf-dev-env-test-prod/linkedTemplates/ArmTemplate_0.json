			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_rest_parquet'"
		},
		"LS_ADLS_DataLake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsmutilplefiles.dfs.core.windows.net/"
		},
		"LS_ADLS_GEN2_SourceFolder_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsmutilplefiles.dfs.core.windows.net/"
		},
		"LS_ADLS_GEN_Validation_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsmutilplefiles.dfs.core.windows.net/"
		},
		"LS_ADLS_Gen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsmutilplefiles.dfs.core.windows.net/"
		},
